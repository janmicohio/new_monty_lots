# Server Configuration
PORT=8080

# S3-Compatible Storage Configuration
# Set S3_ENABLED=true to sync GeoJSON files from S3-compatible storage
S3_ENABLED=false

# S3 Credentials
S3_ACCESS_KEY_ID=your-access-key-here
S3_SECRET_ACCESS_KEY=your-secret-key-here

# S3 Bucket Configuration
S3_BUCKET=your-bucket-name
S3_REGION=us-east-1

# For DigitalOcean Spaces, set the endpoint to your region
# Examples:
#   NYC3: https://nyc3.digitaloceanspaces.com
#   SFO3: https://sfo3.digitaloceanspaces.com
#   AMS3: https://ams3.digitaloceanspaces.com
#   SGP1: https://sgp1.digitaloceanspaces.com
S3_ENDPOINT=

# Optional: Prefix for files in bucket (e.g., "geojson/" to only sync files in that folder)
S3_PREFIX=

# Optional: Auto-sync on startup (default: true)
S3_AUTO_SYNC=true

# Optional: Periodic sync interval in milliseconds (0 = disabled, default: 0)
# Example: 300000 = sync every 5 minutes
S3_SYNC_INTERVAL=0
